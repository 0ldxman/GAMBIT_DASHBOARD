# Общие переменные для docker compose (локально и Portainer).
# Скопируйте в .env и заполните.

# --- Postgres ---
POSTGRES_USER=gambit
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=gambit

# --- Backend ---
MASTER_PASSWORD=change-me-master
SECRET_KEY=change-me-random-long-secret
INTERNAL_API_KEY=change-me-shared-with-bot
BACKEND_PORT=8000
# Источник(и) фронта для CORS. Для nginx-фронта запросы идут через /api, CORS не нужен,
# но оставьте адрес, откуда открываете дашборд.
CORS_ORIGINS=["http://localhost:8080"]

# --- Frontend ---
FRONTEND_PORT=8080

# --- Bot ---
DISCORD_BOT_TOKEN=
BOT_POLL_SECONDS=15

# --- Только для docker-compose.portainer.yml (готовые образы из GHCR) ---
# Владелец репозитория (ghcr.io/<OWNER>/gambit-*), обычно ваш GitHub-логин в нижнем регистре.
IMAGE_OWNER=your-github-username
IMAGE_TAG=latest
