# Токен Discord-бота (Bot → Token в Developer Portal).
DISCORD_BOT_TOKEN=

# Базовый URL backend API. В docker-compose = http://backend:8000
API_BASE=http://localhost:8000

# Общий секрет с backend (должен совпадать с INTERNAL_API_KEY бэкенда).
INTERNAL_API_KEY=dev-internal-key-change-me

# Интервал опроса вердов к отправке, сек.
BOT_POLL_SECONDS=15
