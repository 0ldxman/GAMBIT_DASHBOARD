# Скопируйте в .env (или задайте переменные в Portainer/окружении).

# Подключение к Postgres (внутри docker host = имя сервиса "db").
DATABASE_URL=postgresql+asyncpg://gambit:gambit@localhost:5432/gambit

# Общий пароль мастеров для входа в дашборд.
MASTER_PASSWORD=changeme

# Ключ подписи сессионных токенов (сгенерируйте случайный длинный).
SECRET_KEY=please-change-me-to-a-random-secret

# Разрешённые источники фронтенда (JSON-массив).
CORS_ORIGINS=["http://localhost:5173"]

# Токен Discord-бота (нужен боту, а не API).
DISCORD_BOT_TOKEN=

# --- используется docker-compose ---
POSTGRES_USER=gambit
POSTGRES_PASSWORD=gambit
POSTGRES_DB=gambit
BACKEND_PORT=8000
